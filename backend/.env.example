## Backend environment (copy to `backend/.env`)
#
# IMPORTANT:
# - This file is safe to commit.
# - Do NOT commit `backend/.env` (contains secrets). It is ignored by `.gitignore`.

# If unset/empty, `/v1/score` uses deterministic mock scoring.
OPENAI_API_KEY=

# Optional scoring config
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=90
SCORE_PROMPT_VARIANT=full

# Optional STT config
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# WHISPER_LANGUAGE=en

